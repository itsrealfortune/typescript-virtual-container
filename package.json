{
  "name": "typescript-virtual-container",
  "description": "In-memory SSH server with virtual filesystem and typed programmatic API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "version": "1.2.3",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/itsrealfortune/typescript-virtual-container"
  },
  "keywords": [
    "ssh",
    "virtual-filesystem",
    "typescript",
    "testing",
    "automation",
    "shell"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "format": "bunx --bun @biomejs/biome format --write ./src",
    "check": "bunx --bun @biomejs/biome check ./src",
    "lint": "bunx --bun @biomejs/biome lint ./src",
    "lint:write": "bunx --bun @biomejs/biome lint --write ./src",
    "test": "bunx --bun @biomejs/biome test ./src",
    "build": "tsc --project tsconfig.json",
    "deploy:npm": "npm publish --access public",
    "standalone-build": "bunx esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=standalone.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/bun": "latest",
    "@types/node": "^25.6.0",
    "@types/ssh2": "^1.15.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "ssh2": "^1.17.0"
  }
}