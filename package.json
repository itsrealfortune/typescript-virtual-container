{
  "name": "typescript-virtual-container",
  "description": "In-memory SSH server with virtual filesystem and typed programmatic API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "version": "1.2.8",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/itsrealfortune/typescript-virtual-container"
  },
  "keywords": [
    "ssh",
    "virtual-filesystem",
    "typescript",
    "testing",
    "automation",
    "shell"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "format": "bunx --bun @biomejs/biome format --write ./src",
    "check": "bunx --bun @biomejs/biome check ./src",
    "lint": "bunx --bun @biomejs/biome lint ./src",
    "lint:write": "bunx --bun @biomejs/biome lint --write ./src",
    "test": "bunx --bun @biomejs/biome test ./src",
    "build": "tsc --project tsconfig.json",
    "deploy:npm": "npm publish --access public",
    "bench": "rm -rf .benchmark-shells/ && bun benchmark-virtualshell.ts",
    "publish-package": "bash ./scripts/publish-package.sh",
    "standalone-build": "bunx esbuild src/standalone.ts --bundle --platform=node --target=node18 --outfile=standalone.js --tree-shaking=true --minify --sourcemap"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "@types/ssh2": "^1.15.5",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "ssh2": "^1.17.0"
  }
}