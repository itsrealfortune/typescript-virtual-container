{
    "assist": {
        "actions": {
            "source": {
                "organizeImports": "off"
            }
        }
    },
    "linter": {
        "rules": {
            "nursery": {
                "useAwaitThenable": "error",
                "noFloatingPromises": "error",
                "noMisusedPromises": "error"
            },
            "suspicious": {
                "noDebugger": "off",
                "useAwait": "error"
            },
            "complexity": {
                "useArrowFunction": "error"
            },
            "style": {
                "noShoutyConstants": "warn",
                "noNonNullAssertion": "off",
                "useNamingConvention": {
                    "options": {
                        "conventions": [
                            {
                                "selector": {
                                    "kind": "variable"
                                },
                                "match": "[ij]|(.*)"
                            },
                            {
                                "match": "(.{2,})"
                            },
                            {
                                "selector": {
                                    "kind": "classMember",
                                    "modifiers": [
                                        "private"
                                    ]
                                },
                                "match": "_(.*)"
                            },
                            {
                                "selector": {
                                    "kind": "classProperty",
                                    "modifiers": [
                                        "static",
                                        "readonly"
                                    ]
                                },
                                "formats": [
                                    "CONSTANT_CASE"
                                ]
                            },
                            {
                                "selector": {
                                    "kind": "const",
                                    "scope": "global"
                                },
                                "match": "__(.+)__|_SPECIAL_|(.+)",
                                "formats": [
                                    "CONSTANT_CASE"
                                ]
                            },
                            {
                                "selector": {
                                    "kind": "interface"
                                },
                                "match": "I(.*)|(.*?)Error",
                                "formats": [
                                    "PascalCase"
                                ]
                            }
                        ]
                    }
                }
            }
        }
    },
    "formatter": {
        "enabled": false,
        "formatWithErrors": false,
        "attributePosition": "auto",
        "indentStyle": "tab",
        "indentWidth": 2,
        "lineWidth": 80,
        "lineEnding": "lf"
    },
    "files": {
        "ignoreUnknown": true,
        "includes": [
            "**/*.ts",
            "**/*.tsx"
        ]
    }
}